# Last Man Standing Server Configuration

# ─── Networking ───
SERVER_HOST=0.0.0.0
WS_PORT=8765
API_PORT=8000

# ─── Security ───
SECRET_KEY=generate_some_secure_random_key_here

# ─── Database ───
DATABASE_URL=lms_game.db

# ─── Firebase Cloud Messaging (Optional) ───
# If empty, push notifications will be simulated in the console logs instead
FCM_SERVER_KEY=

# ─── Game Tuning (Seconds) ───
# Reduce these for quick developer testing
BOSS_MIN_SLEEP=120
BOSS_MAX_SLEEP=240
BOSS_WARNING_SEC=30
BOSS_HUNT_SEC=30
